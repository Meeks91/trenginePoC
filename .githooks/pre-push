#!/bin/bash
# Installed via: git config core.hooksPath .githooks

export PY_COLORS=1
cd "seeding/crawl4ai" || exit 1

# Activate the project venv so all deps (crawl4ai, names_dataset, etc.) are available
# shellcheck disable=SC1091
source ../.venv/bin/activate || { echo "❌ Could not activate venv at seeding/.venv"; exit 1; }

# ── Step 1: Ruff lint check ─────────────────────────────────────
echo "Running Ruff lint check..."

if ! ruff check . 2>&1 | head -50; then
    echo "========================================="
    echo "❌ PRE-PUSH FAILED: Ruff lint errors found!"
    echo "Fix lint errors before pushing."
    echo "Run: ruff check . --fix"
    echo "========================================="
    exit 1
fi

echo "✅ Ruff passed."

# ── Step 2: mypy type checks ────────────────────────────────────
echo "Running mypy type checks..."

if ! python3 -m mypy . 2>&1 | head -50; then
    echo "========================================="
    echo "❌ PRE-PUSH FAILED: mypy type errors found!"
    echo "Fix type errors before pushing."
    echo "========================================="
    exit 1
fi

echo "✅ mypy passed."

# ── Step 3: ALL tests (including network & slow) ────────────────
echo "Running ALL test suites (including network & slow tests) before push..."


PYTEST_OPTS=(-o "addopts=" -q --disable-warnings)
if [ -z "$GEMINI_API_KEY" ]; then
    echo "⚠️  GEMINI_API_KEY not set — skipping @pytest.mark.network tests."
    PYTEST_OPTS+=(-m "not network")
fi

if ! python3 -m pytest tests/ "${PYTEST_OPTS[@]}"; then
    echo "========================================="
    echo "❌ PRE-PUSH FAILED: Comprehensive test suite broken!"
    echo "Please fix the failing tests before pushing."
    echo "========================================="
    exit 1
fi

echo "✅ All tests passed. Ready to push."
exit 0
